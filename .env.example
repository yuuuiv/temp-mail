# 后端 API 基地址。留空则使用与前端同源（推荐把前端与 worker 部署在同一域名下）。
# 若前后端分离，填写你的 worker 地址，例如：
# VITE_API_BASE=https://your-worker.example.workers.dev
VITE_API_BASE=

# 统一账户服务（C:\Users\yuuuiv\Downloads\auth-main / awsl-auth）
# 部署到 Vercel 后填写它的域名，例如：https://your-auth-app.vercel.app
VITE_AUTH_API_BASE=
# 对应 auth-main 后端 app_settings__N__app_id / app_secret
VITE_AUTH_APP_ID=demo
VITE_AUTH_APP_SECRET=
# 第三方 OAuth 直接回调路径；完整地址为 http(s)://前端域名/auth/callback/<provider>
VITE_AUTH_CALLBACK_PATH=/auth/callback
